{
  "name": "zafraweb",
  "version": "1.0.1",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "npx expo start --port 8081",
    "adb:reverse": "cmd /c \"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe\" reverse tcp:8081 tcp:8081",
    "start:android": "cmd /c \"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe reverse tcp:8081 tcp:8081 && set EXPO_OFFLINE=1&& npx expo start --android --port 8081 --localhost\"",
    "start:android:lan": "npx expo start --android --port 8081 --lan",
    "env:supabase": "node scripts/patch-supabase-env.cjs",
    "android:go": "cmd /c \"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe reverse tcp:8081 tcp:8081 && set EXPO_OFFLINE=1&& set CI=1&& npx expo start --android --port 8081\"",
    "start:tunnel": "npx expo start --tunnel --port 8081",
    "android": "cmd /c \"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe reverse tcp:8081 tcp:8081 && npx expo start --android --port 8081 --localhost\"",
    "ios": "npx expo start --ios --port 8081",
    "android:apk": "cmd /c \"%LOCALAPPDATA%\\Android\\Sdk\\platform-tools\\adb.exe reverse tcp:8081 tcp:8081 && npx expo run:android\"",
    "android:assemble-release": "cmd /c \"set NODE_ENV=production&& cd /d android && gradlew.bat --stop & gradlew.bat assembleRelease\"",
    "eas:build:apk": "npx eas-cli@latest build -p android --profile preview",
    "lint": "eslint App.tsx src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check",
    "doctor": "npx expo-doctor",
    "assets:png": "node scripts/convert-assets-jpg-to-png.cjs",
    "supabase:bundle-envio": "node scripts/build-supabase-envio-unico.cjs",
    "supabase:login": "npx supabase login",
    "supabase:link": "node scripts/supabase-link.cjs",
    "supabase:sql": "node scripts/supabase-run-sql.cjs",
    "supabase:apply-deltas": "node scripts/supabase-apply-all-remote.cjs",
    "supabase:gen-deltas-bundle": "node scripts/generate-aplicar-deltas-recientes.cjs",
    "supabase:fn:create-perito": "npx supabase functions deploy create-perito-account",
    "supabase:fn:buyer-push": "npx supabase functions deploy process-buyer-push-outbox --no-verify-jwt",
    "supabase:fn:deploy-all": "node scripts/supabase-deploy-functions.cjs",
    "supabase:db:push": "npx supabase db push",
    "supabase:push:setup": "node scripts/supabase-push-outbox-full-setup.cjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@supabase/supabase-js": "^2.43.4",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "expo": "~54.0.0",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "sharp": "^0.34.5",
    "supabase": "^2.83.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
