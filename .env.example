# Copia este archivo como .env y rellena con tus valores reales.
# NUNCA subas el .env al repositorio.

# ─── Credenciales DEV (__DEV__ solo) ────────────────────────────────────────
# Prellenar login en Expo Go / emulador. NUNCA subas valores reales al repo.
# Login genérico (rellena cualquiera de los dos para prellenar el campo al abrir la app)
# EXPO_PUBLIC_DEV_LOGIN_EMAIL=dev@ejemplo.com
# EXPO_PUBLIC_DEV_LOGIN_PASSWORD=secret
#
# Presets por rol (botones rápidos en la pantalla de login, solo en __DEV__)
# EXPO_PUBLIC_DEV_LOGIN_AGRICULTOR_EMAIL=agricultor@ejemplo.com
# EXPO_PUBLIC_DEV_LOGIN_AGRICULTOR_PASSWORD=secret
# EXPO_PUBLIC_DEV_LOGIN_EMPRESA_EMAIL=empresa@ejemplo.com
# EXPO_PUBLIC_DEV_LOGIN_EMPRESA_PASSWORD=secret
# EXPO_PUBLIC_DEV_LOGIN_COMPRADOR_EMAIL=comprador@ejemplo.com
# EXPO_PUBLIC_DEV_LOGIN_COMPRADOR_PASSWORD=secret
# EXPO_PUBLIC_DEV_LOGIN_TRANSPORTE_EMAIL=transporte@ejemplo.com
# EXPO_PUBLIC_DEV_LOGIN_TRANSPORTE_PASSWORD=secret
# EXPO_PUBLIC_DEV_LOGIN_AGROTIENDA_EMAIL=agrotienda@ejemplo.com
# EXPO_PUBLIC_DEV_LOGIN_AGROTIENDA_PASSWORD=secret
# EXPO_PUBLIC_DEV_LOGIN_CEO_EMAIL=ceo@ejemplo.com
# EXPO_PUBLIC_DEV_LOGIN_CEO_PASSWORD=secret
# EXPO_PUBLIC_DEV_LOGIN_PERITO_EMAIL=perito@ejemplo.com
# EXPO_PUBLIC_DEV_LOGIN_PERITO_PASSWORD=secret

# ─── Supabase ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Opcional: contraseña de Postgres (Supabase → Settings → Database) para `npm run supabase:link` sin prompt
# SUPABASE_DB_PASSWORD=

# ─── KYC ────────────────────────────────────────────────────────────────────
# KYC global en la app (true = sin pantalla KYC, registros nuevos con kyc verified)
# EXPO_PUBLIC_KYC_DISABLED=true

# Si KYC_DISABLED=false, puedes listar correos que sí omiten KYC solo en desarrollo (__DEV__):
# EXPO_PUBLIC_KYC_BYPASS_EMAILS=admin@ejemplo.com

# ─── AI / Gemini ─────────────────────────────────────────────────────────────
# Gemini se consume mediante la Edge Function segura `process-gemini`.
# Configura el secreto `GEMINI_API_KEY` en Supabase; la clave ya no vive en el cliente.
# Opcional en .env (para `npm run supabase:fn:deploy-all` → sube el secret al proyecto):
# GEMINI_API_KEY=
# Opcional: modelo (por defecto gemini-2.5-flash). Si Google depreca el nombre, cámbialo aquí.
# EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# ─── Push Notifications ──────────────────────────────────────────────────────
# Push (Edge `process-buyer-push-outbox`): token en https://expo.dev/settings/access-tokens
# EXPO_ACCESS_TOKEN=
# Secreto para invocar la función (cron / sin JWT): mismo valor en Supabase secrets y en el header
# BUYER_PUSH_OUTBOX_SECRET=

# ─── Mapas y Clima ───────────────────────────────────────────────────────────
EXPO_PUBLIC_OPENWEATHER_KEY=tu_openweather_key

# Google Maps (Android): Maps SDK for Android, paquete com.unicornio.agro
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=tu_clave_maps_android

# ─── Auth Deep Links ─────────────────────────────────────────────────────────
# Recuperación de contraseña (deep link): en Supabase → Authentication → URL Configuration
# añade a «Redirect URLs» la URL que imprime la app, p. ej.:
#   zafraclic://reset-password
#   exp://127.0.0.1:8081/--/reset-password   (Expo Go + emulador; ajusta puerto/host si cambia)

# ─── CHECKLIST DE PRODUCCIÓN ─────────────────────────────────────────────────
# Antes de publicar en Google Play / App Store, valida lo siguiente:
#
# 1. SUPABASE STORAGE BUCKETS (Supabase → Storage → Buckets)
#    Crear los siguientes buckets con "Public" activado si necesitas URLs públicas:
#    ┌─────────────────────────────┬──────────┬──────────────────────────────────────────────────────┐
#    │ Bucket name                 │ Public   │ Descripción                                          │
#    ├─────────────────────────────┼──────────┼──────────────────────────────────────────────────────┤
#    │ avatars                     │ Sí       │ Fotos de perfil de usuarios                          │
#    │ cosechas-fotos              │ Sí       │ Imágenes de cosechas publicadas                      │
#    │ insumos-fotos               │ Sí       │ Imágenes de productos en agrotienda                  │
#    │ chat-media                  │ Sí       │ Imágenes enviadas en chats (cosechas, logística)     │
#    │ insumo-chat-media           │ Sí       │ Imágenes enviadas en chats de insumos                │
#    │ maquinaria-fotos            │ Sí       │ Imágenes de maquinaria en alquiler                   │
#    │ inspection-docs             │ No       │ PDFs de informes de perito (privados)                │
#    │ perito-signatures           │ No       │ Firmas digitales de peritos (privadas)               │
#    └─────────────────────────────┴──────────┴──────────────────────────────────────────────────────┘
#    RLS policy sugerida para buckets públicos:
#       - SELECT: anon y authenticated (para ver fotos)
#       - INSERT: authenticated (solo usuarios autenticados suben)
#       - DELETE: authenticated (solo el dueño; usar perfil_id en el path)
#
# 2. SECRETS EN EDGE FUNCTIONS (supabase secrets set --env-file .env.prod)
#    Obligatorios para producción:
#    - GEMINI_API_KEY          (Gemini Vision / scanner IA)
#    - EXPO_ACCESS_TOKEN       (push notifications vía Expo)
#    - BUYER_PUSH_OUTBOX_SECRET (seguridad del cron de push)
#
# 3. pg_cron PARA PUSH OUTBOX (solo en proyecto de producción)
#    Ejecutar en SQL Editor de producción:
#    SELECT cron.schedule(
#      'process-buyer-push-outbox',
#      '* * * * *',  -- cada minuto
#      $$SELECT net.http_post(
#        url := 'https://TU_PROYECTO.supabase.co/functions/v1/process-buyer-push-outbox',
#        headers := '{"Authorization": "Bearer TU_CRON_SECRET"}'::jsonb,
#        body := '{}'::jsonb
#      )$$
#    );
#
# 4. GOOGLE PLAY / APP STORE
#    - package: com.unicornio.agro (Android) / com.unicornio.agro (iOS)
#    - Construir con: npx eas build --platform android --profile production
#    - Subir con: npx eas submit --platform android

